PORT=4000
MONGODB_URI=mongodb://localhost:27017/workshift-notifier

# GitHub OAuth (tạo tại https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/api/auth/github/callback

# JWT secret (tự generate: openssl rand -hex 32)
JWT_SECRET=

# Frontend URL (cho redirect sau OAuth)
FRONTEND_URL=http://localhost:5174

# Engineer Management API (URL của backend engineer-management đang chạy)
EM_API_URL=https://your-engineer-management-backend.run.app

# Google Calendar
# Cách 1: API Key (nếu calendar public/shared)
GOOGLE_API_KEY=
# Cách 2: Service Account JSON (1 dòng, cho calendar private)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Calendar ID lịch trực
GOOGLE_CALENDAR_ID=c_93cae9ea9243fc7eb329137b547c18329f7de8069d5064dace1aaeb66df6eab6@group.calendar.google.com
